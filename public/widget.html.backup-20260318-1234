<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CEC News - Widget</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #fff;
            color: #333;
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
        }

        .widget-container {
            max-width: 100%;
            margin: 0 auto;
            background: #fff;
            min-height: 100vh;
        }

        @media (max-width: 500px) {
            .widget-container {
                max-width: 400px;
            }
        }

        /* Header Banner */
        .widget-header {
            background: #fff;
            padding: 12px 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-bottom: 1px solid #e2e8f0;
        }

        .widget-banner {
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            width: 100%;
        }

        .widget-logo {
            height: 40px;
            width: auto;
            flex-shrink: 0;
        }

        .widget-title-group {
            margin-left: 12px;
        }

        .widget-title {
            color: #1e3a5f;
            font-size: 15px;
            font-weight: 600;
        }

        /* Featured News - Mobile Reel Style (default) */
        .featured-news {
            position: relative;
            background: #000;
        }

        .featured-container {
            position: relative;
            display: flex;
            flex-direction: column;
        }

        .featured-media-wrapper {
            position: relative;
        }

        .featured-media {
            width: 100%;
            aspect-ratio: 9/16;
            max-height: 500px;
            object-fit: cover;
            display: block;
        }

        .featured-video {
            width: 100%;
            aspect-ratio: 9/16;
            max-height: 500px;
            border: none;
            display: block;
        }

        .featured-overlay {
            padding: 16px;
            background: #f8f9fa;
            border-bottom: 1px solid #e2e8f0;
        }

        .featured-category {
            display: inline-block;
            background: #dc2626;
            color: #fff;
            font-size: 9px;
            font-weight: 600;
            padding: 3px 8px;
            border-radius: 4px;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .featured-title {
            font-size: 16px;
            font-weight: 600;
            color: #1a202c;
            line-height: 1.35;
            margin-bottom: 8px;
        }

        .featured-excerpt {
            font-size: 13px;
            color: #4a5568;
            line-height: 1.45;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .featured-date {
            font-size: 11px;
            color: #a0aec0;
            margin-top: 8px;
        }

        /* Desktop: Side by side - video left, news list right */
        @media (min-width: 700px) {
            .featured-container {
                flex-direction: row;
                align-items: flex-start;
            }

            .featured-media-wrapper {
                flex: 0 0 300px;
                position: relative;
            }

            .featured-media,
            .featured-video {
                width: 300px;
                height: 400px;
                aspect-ratio: auto;
                max-height: 400px;
                object-fit: cover;
            }

            .featured-overlay {
                display: none;
            }

            .news-list {
                flex: 1;
                max-height: 400px;
                overflow-y: auto;
                border-left: 1px solid #e2e8f0;
            }

            .widget-container {
                max-width: 800px;
            }
        }

        /* News List - Text only, no images */
        .news-list {
            padding: 0;
        }

        .news-item {
            display: block;
            padding: 10px 16px;
            text-decoration: none;
            color: inherit;
            transition: background 0.2s;
            border-bottom: 1px solid #f0f0f0;
        }

        .news-item:hover {
            background: #f8f9fa;
        }

        .news-item:last-child {
            border-bottom: none;
        }

        .news-content {
            width: 100%;
        }

        .news-category {
            display: inline-block;
            font-size: 9px;
            font-weight: 600;
            color: #2c5282;
            text-transform: uppercase;
            letter-spacing: 0.3px;
            margin-bottom: 3px;
        }

        .news-title {
            font-size: 12px;
            font-weight: 500;
            color: #1a202c;
            line-height: 1.35;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            margin-bottom: 2px;
        }

        .news-date {
            font-size: 10px;
            color: #a0aec0;
        }

        /* Footer */
        .widget-footer {
            background: #f8f9fa;
            padding: 12px 16px;
            text-align: center;
            border-top: 1px solid #e2e8f0;
        }

        .footer-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: #2c5282;
            text-decoration: none;
            font-size: 12px;
            font-weight: 500;
        }

        .footer-link:hover {
            color: #1a365d;
        }

        .footer-link svg {
            width: 14px;
            height: 14px;
        }

        /* Loading */
        .loading {
            padding: 20px;
            text-align: center;
            color: #718096;
            font-size: 13px;
        }
    </style>
</head>
<body>
    <div class="widget-container">
        <!-- Header Banner -->
        <header class="widget-header">
            <a href="https://cec.org.co" target="_blank" class="widget-banner">
                <img src="images/logo.svg" alt="CEC Logo" class="widget-logo" onerror="this.style.display='none'">
                <div class="widget-title-group">
                    <div class="widget-title">Noticias CEC</div>
                </div>
            </a>
        </header>

        <!-- Featured News (First with video/image) -->
        <div class="featured-news" id="featuredNews">
            <div class="loading">Cargando...</div>
        </div>

        <!-- News List (6 items) -->
        <div class="news-list" id="newsList">
            <div class="loading">Cargando noticias...</div>
        </div>

        <!-- Footer -->
        <footer class="widget-footer">
            <a href="https://cec.org.co/sistema-informativo/" target="_blank" class="footer-link">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                </svg>
                Ver más en CEC.org.co
            </a>
        </footer>
    </div>

    <script>
        // Cargar noticias
        async function loadNews() {
            try {
                const response = await fetch('news-data.json');
                const news = await response.json();
                renderNews(news);
            } catch (error) {
                console.error('Error loading news:', error);
                document.getElementById('featuredNews').innerHTML = `
                    <div class="featured-overlay">
                        <p style="color:#718096;font-size:13px;">Error al cargar. <a href="https://cec.org.co" target="_blank">Visitar CEC.org.co</a></p>
                    </div>
                `;
            }
        }

        function renderNews(news) {
            if (!news || news.length === 0) return;

            const featured = news[0];
            const remaining = news.slice(1, 7);

            // Render featured (first news) with info below video
            let featuredHtml = '<div class="featured-container">';
            
            // Media wrapper with video/image
            featuredHtml += '<div class="featured-media-wrapper">';
            
            // Mostrar video o imagen
            if (featured.video && featured.video.trim() !== '') {
                featuredHtml += `
                    <iframe 
                        id="featuredVideo"
                        class="featured-video"
                        src="${featured.video}?autoplay=0&rel=0"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        allowfullscreen>
                    </iframe>
                `;
            } else {
                featuredHtml += `
                    <img 
                        class="featured-media" 
                        src="${featured.image}" 
                        alt="${featured.title}"
                        loading="lazy"
                        onerror="this.src='https://via.placeholder.com/400x500/e2e8f0/a0aec0?text=CEC'">
                `;
            }
            
            // Media wrapper - sin botón extra
            featuredHtml += '</div>';
            
            // Info section below video (mobile) / hidden on desktop
            featuredHtml += `
                <div class="featured-overlay">
                    <span class="featured-category">${featured.category}</span>
                    <h2 class="featured-title">${featured.title}</h2>
                    <p class="featured-excerpt">${featured.excerpt}</p>
                    <span class="featured-date">${featured.date}</span>
                </div>
            </div>
            `;

            document.getElementById('featuredNews').innerHTML = featuredHtml;

            // Render news list - text only, no images
            const newsList = document.getElementById('newsList');
            newsList.innerHTML = remaining.map(item => `
                <a href="${item.url}" target="_blank" class="news-item">
                    <div class="news-content">
                        <span class="news-category">${item.category}</span>
                        <h3 class="news-title">${item.title}</h3>
                        <span class="news-date">${item.date}</span>
                    </div>
                </a>
            `).join('');
        }

        // Iniciar
        loadNews();
    </script>
</body>
</html>