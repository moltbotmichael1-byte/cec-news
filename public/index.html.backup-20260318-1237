<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CEC News Widget - Conferencia Episcopal de Colombia</title>
    <meta name="description" content="Widget de noticias de la Conferencia Episcopal de Colombia para incrustar en tu sitio web. Actualización automática, responsive, sin dependencias.">
    <meta name="keywords" content="CEC, Conferencia Episcopal, Colombia, noticias, widget, iframe, embed">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #1e3a5f 0%, #2c5282 100%);
            min-height: 100vh;
            padding: 20px;
            color: #333;
        }
        .container {
            max-width: 800px;
            margin: 0 auto;
        }
        .header {
            text-align: center;
            padding: 30px 20px;
            background: white;
            border-radius: 16px;
            margin-bottom: 24px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.15);
        }
        .logo {
            max-width: 150px;
            margin-bottom: 12px;
        }
        h1 { color: #1e3a5f; font-size: 1.6rem; margin-bottom: 8px; }
        .subtitle { color: #666; font-size: 0.95rem; line-height: 1.5; max-width: 500px; margin: 0 auto; }
        
        /* Generator Tool */
        .generator {
            background: white;
            border-radius: 16px;
            padding: 24px;
            margin-bottom: 24px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.15);
        }
        .generator h2 {
            color: #1e3a5f;
            margin-bottom: 8px;
            font-size: 1.1rem;
        }
        .generator p {
            color: #666;
            margin-bottom: 20px;
            font-size: 0.9rem;
        }
        .options {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 16px;
            margin-bottom: 20px;
        }
        .option-group label {
            display: block;
            color: #333;
            font-weight: 500;
            margin-bottom: 6px;
            font-size: 0.85rem;
        }
        .option-group input, .option-group select {
            width: 100%;
            padding: 10px;
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            font-size: 0.9rem;
        }
        .option-group input:focus, .option-group select:focus {
            outline: none;
            border-color: #2c5282;
        }
        .code-box {
            background: #1e293b;
            border-radius: 8px;
            padding: 16px;
            margin-bottom: 16px;
            overflow-x: auto;
        }
        .code-box code {
            color: #e2e8f0;
            font-family: 'Monaco', 'Menlo', 'Consolas', monospace;
            font-size: 0.8rem;
            line-height: 1.5;
            white-space: pre;
        }
        .copy-btn {
            background: linear-gradient(135deg, #2c5282 0%, #1e3a5f 100%);
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 8px;
            font-size: 0.95rem;
            font-weight: 500;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .copy-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(44, 82, 130, 0.3);
        }
        
        /* Preview */
        .preview-section {
            background: white;
            border-radius: 16px;
            padding: 24px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.15);
        }
        .preview-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
        }
        .preview-header h2 {
            color: #1e3a5f;
            font-size: 1.1rem;
        }
        .preview-link {
            color: #2c5282;
            text-decoration: none;
            font-size: 0.85rem;
        }
        .preview-link:hover {
            text-decoration: underline;
        }
        .preview-frame {
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            overflow: hidden;
            background: #f8fafc;
        }
        .preview-frame iframe {
            width: 100%;
            border: none;
            display: block;
        }
        
        .footer {
            text-align: center;
            padding: 20px;
            color: rgba(255,255,255,0.8);
            font-size: 0.85rem;
        }
        .footer a {
            color: white;
            text-decoration: none;
        }
        .footer a:hover {
            text-decoration: underline;
        }
        
        @media (max-width: 600px) {
            .options {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <img src="images/logo.svg" alt="CEC Logo" class="logo" onerror="this.style.display='none'">
            <h1>CEC News Widget</h1>
            <p class="subtitle">Incrusta noticias de la Conferencia Episcopal de Colombia en tu sitio web. Diseño responsive: video + lista de noticias.</p>
        </div>
        
        <!-- Generator Tool -->
        <div class="generator">
            <h2>Generador de iframe</h2>
            <p>Personaliza las dimensiones del widget. El código generado puedes copiarlo directamente en tu HTML.</p>
            
            <div class="options">
                <div class="option-group">
                    <label for="width">Ancho</label>
                    <input type="text" id="width" value="400" placeholder="400 o 100%">
                </div>
                <div class="option-group">
                    <label for="height">Alto (px)</label>
                    <input type="number" id="height" value="800" placeholder="800">
                </div>
                <div class="option-group">
                    <label for="border">Bordes</label>
                    <select id="border">
                        <option value="12">Redondeados (12px)</option>
                        <option value="0">Sin bordes</option>
                        <option value="8">Redondeados (8px)</option>
                    </select>
                </div>
            </div>
            
            <div class="code-box">
                <code id="iframeCode">&lt;iframe 
  src="https://cecnews.pages.dev/widget.html" 
  width="400" 
  height="800" 
  frameborder="0"
  loading="lazy"
  style="border-radius: 12px;"&gt;
&lt;/iframe&gt;</code>
            </div>
            
            <button class="copy-btn" onclick="copyCode()">
                📋 Copiar código
            </button>
        </div>
        
        <!-- Preview -->
        <div class="preview-section">
            <div class="preview-header">
                <h2>Vista previa</h2>
                <a href="widget.html" target="_blank" class="preview-link">Abrir widget completo</a>
            </div>
            <div class="preview-frame">
                <iframe id="previewFrame" src="widget.html" loading="lazy"></iframe>
            </div>
        </div>
        
        <div class="footer">
            <p>Las noticias se obtienen de <a href="https://cec.org.co" target="_blank">CEC.org.co</a>
            <br>Diseño inspirado en Vatican News Widget</p>
        </div>
    </div>
    
    <script>
        const baseURL = 'https://cecnews.pages.dev/widget.html';
        
        function updateCode() {
            const width = document.getElementById('width').value;
            const height = document.getElementById('height').value;
            const border = document.getElementById('border').value;
            
            const widthStyle = width.includes('%') ? `"${width}"` : `"${width}"`;
            
            const code = `&lt;iframe 
  src="${baseURL}" 
  width=${widthStyle}
  height="${height}" 
  frameborder="0"
  loading="lazy"
  style="border-radius: ${border}px;"&gt;
&lt;/iframe&gt;`;
            
            document.getElementById('iframeCode').innerHTML = code;
            
            // Update preview height
            document.getElementById('previewFrame').style.height = Math.min(height, 600) + 'px';
        }
        
        function copyCode() {
            const width = document.getElementById('width').value;
            const height = document.getElementById('height').value;
            const border = document.getElementById('border').value;
            
            const widthStyle = width.includes('%') ? `"${width}"` : `"${width}"`;
            
            const code = `<iframe 
  src="${baseURL}" 
  width=${widthStyle}
  height="${height}" 
  frameborder="0"
  loading="lazy"
  style="border-radius: ${border}px;">
</iframe>`;
            
            navigator.clipboard.writeText(code).then(() => {
                const btn = document.querySelector('.copy-btn');
                btn.textContent = '✓ Copiado!';
                setTimeout(() => {
                    btn.textContent = '📋 Copiar código';
                }, 2000);
            });
        }
        
        // Update on input change
        document.getElementById('width').addEventListener('input', updateCode);
        document.getElementById('height').addEventListener('input', updateCode);
        document.getElementById('border').addEventListener('change', updateCode);
        
        // Set initial preview height
        document.getElementById('previewFrame').style.height = '600px';
    </script>
</body>
</html>